{
  "name": "imdbwatch",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "node scripts/test-parser.mjs",
    "dev": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply imdbwatcharr-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply imdbwatcharr-db --remote"
  },
  "dependencies": {
    "@cloudflare/playwright": "^1.3.0"
  },
  "devDependencies": {
    "wrangler": "^4.11.1"
  }
}
